# ============================================================================
# VARIABLES DE ENTORNO - VENDAMÁS
# ============================================================================
# Copia este archivo a .env.local y completa con tus credenciales reales
# NUNCA commitear .env.local - está en .gitignore

# ============================================================================
# SUPABASE - BASE DE DATOS Y AUTENTICACIÓN
# ============================================================================
# Obtener en https://app.supabase.com -> Configuración del proyecto

# URL de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anónima de Supabase (segura para usar en el frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de rol de servicio (SOLO en servidor, NUNCA exponerla en frontend)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# APP - CONFIGURACIÓN GENERAL
# ============================================================================

# URL pública de la aplicación (usado para OAuth redirects, emails, etc)
# En desarrollo: http://localhost:3000
# En producción: https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================================
# OPCIONAL - INTEGRACIONES FUTURAS
# ============================================================================

# URL pública de la plataforma (dominio principal SaaS)
NEXT_PUBLIC_PLATFORM_DOMAIN=venda-mas.vercel.app

# Opcional: registro automático de dominios en Vercel (Settings → Domains)
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_CNAME_TARGET=cname.vercel-dns.com
# VERCEL_APEX_IP=76.76.21.21

# Mercado Pago — OAuth producción + credenciales checkout
# MP_MODE=test | production
# NEXT_PUBLIC_MP_MODE=test  # debe coincidir con MP_MODE (badge UI)
# NEXT_MP_CLIENT_ID=7658886029761092
# NEXT_MP_CLIENT_SECRET=APP_USR-...
# NEXT_MP_REDIRECT_URI=https://vendamas.app/api/mercadopago/auth
# MP_ACCESS_TOKEN_TEST=TEST-...
# MP_PUBLIC_KEY_TEST=TEST-...
# MP_ACCESS_TOKEN_PROD=APP_USR-...
# MP_PUBLIC_KEY_PROD=APP_USR-...

# Cron de facturación (Vercel Cron)
# CRON_SECRET=generar-un-secreto-largo-y-aleatorio

# Resend — emails transaccionales
# RESEND_API_KEY=re_xxxxxxxxxxxxx
# FROM_EMAIL=noreply@vendemas.app

# ============================================================================
# MONITOREO Y ANALYTICS
# ============================================================================

# Sentry - errores y performance (https://sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://tu-dsn@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=token-para-source-maps
# SENTRY_ORG=tu-organizacion
# SENTRY_PROJECT=nombre-exacto-del-proyecto-en-sentry
# SENTRY_UPLOAD_SOURCE_MAPS=true  # solo si org/proyecto/token son correctos

# PostHog - analytics de producto (https://posthog.com)
# NEXT_PUBLIC_POSTHOG_KEY=phc_tu-api-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. Este archivo es un TEMPLATE - nunca commitear credenciales reales
# 2. Crear .env.local con valores reales en cada máquina
# 3. En Vercel: ir a Settings -> Environment Variables para agregar estas
# 4. Las variables con prefijo NEXT_PUBLIC_ son públicas (visibles en el cliente)
# 5. Las demás son privadas (solo en el servidor)
